DATABASE_URL=postgresql://finance:finance@localhost:5432/finance?sslmode=disable
APP_PASSWORD=

# LLM — OpenAI takes precedence if set; otherwise LiteLLM proxy is used
OPENAI_API_KEY=
LITELLM_API_KEY=
LITELLM_BASE_URL=https://your-litellm-proxy.example.com/v1

# Optional: override the default model (gpt-5.4-mini)
AI_MODEL=

# PDF → image rasterizer service (poppler). Defaults to localhost for local dev;
# docker-compose sets this to http://pdf-renderer:5001 automatically.
PDF_RENDERER_URL=http://localhost:5001
